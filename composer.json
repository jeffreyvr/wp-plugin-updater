{
  "name": "jeffreyvanrossum/wp-plugin-updater",
  "description": "Provides a way to check for plugin updates on a alternative host then wordpress.org.",
  "license": "MIT",
  "authors": [
    {
      "name": "Jeffrey van Rossum",
      "email": "jeffrey@vanrossum.dev"
    }
  ],
  "require": {
    "php": "^8.0"
  },
  "require-dev": {
    "phpcompatibility/php-compatibility": "*",
    "laravel/pint": "^1.2",
    "pestphp/pest": "^4.7"
  },
  "autoload": {
    "psr-4": {
      "Jeffreyvr\\WPPluginUpdater\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "scripts": {
    "format": [
      "./vendor/bin/pint"
    ],
    "test": [
      "./vendor/bin/pest"
    ]
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
